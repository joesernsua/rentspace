rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userHasRole(role) {
      return signedIn()
        && exists(userDoc(request.auth.uid))
        && (
          get(userDoc(request.auth.uid)).data.role == role
          || (
            get(userDoc(request.auth.uid)).data.roles is list
            && get(userDoc(request.auth.uid)).data.roles.hasAny([role])
          )
        );
    }

    function isAdmin() {
      return userHasRole('admin');
    }

    function isBossAdmin() {
      return isAdmin()
        && request.auth.token.email == 'joesernsua@gmail.com';
    }

    function isTenant() {
      return userHasRole('tenant');
    }

    function isOwnerRole() {
      return userHasRole('owner');
    }

    function hasValidCustomerRoles(role) {
      return request.resource.data.roles is list
        && request.resource.data.roles.hasAll([role])
        && request.resource.data.roles.hasOnly(['tenant', 'owner']);
    }

    function hasValidAdminRoles() {
      return request.resource.data.roles is list
        && request.resource.data.roles.hasAll(['admin'])
        && request.resource.data.roles.hasOnly(['admin']);
    }

    function isInvitedAdminCreate(uid) {
      return isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == 'admin'
        && hasValidAdminRoles()
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.name is string
        && request.resource.data.adminEmployeeRole in ['manager', 'property-staff', 'finance-staff']
        && exists(/databases/$(database)/documents/adminInvites/$(request.resource.data.email))
        && request.resource.data.adminEmployeeRole == get(/databases/$(database)/documents/adminInvites/$(request.resource.data.email)).data.employeeRole;
    }

    function isValidPublicEnquiryCreate() {
      return request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.message is string
        && request.resource.data.status == 'new';
    }

    function isValidPublicAppointmentCreate() {
      return request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.preferredDate is string
        && request.resource.data.preferredTime is string
        && request.resource.data.unitType is string
        && request.resource.data.status == 'pending';
    }

    function rentalRequestPath(requestId) {
      return /databases/$(database)/documents/rentalRequests/$(requestId);
    }

    function paymentHistoryMatchesRentalRequest() {
      return request.resource.data.requestId is string
        && exists(rentalRequestPath(request.resource.data.requestId))
        && get(rentalRequestPath(request.resource.data.requestId)).data.tenantId == request.auth.uid
        && get(rentalRequestPath(request.resource.data.requestId)).data.ownerId == request.resource.data.ownerId
        && get(rentalRequestPath(request.resource.data.requestId)).data.propertyId == request.resource.data.propertyId
        && get(rentalRequestPath(request.resource.data.requestId)).data.status == 'approved'
        && get(rentalRequestPath(request.resource.data.requestId)).data.payment.status in ['unpaid', 'paid'];
    }

    function isValidPaymentHistoryCreate() {
      return signedIn()
        && request.resource.data.tenantId == request.auth.uid
        && request.resource.data.status == 'paid'
        && request.resource.data.billingPeriod in ['initial', 'monthly']
        && request.resource.data.paymentMethodType in ['card', 'google-pay', 'fpx']
        && request.resource.data.totalPaid is number
        && request.resource.data.totalPaid > 0
        && request.resource.data.rentDeposit is number
        && request.resource.data.rentDeposit >= 0
        && request.resource.data.utilityDeposit is number
        && request.resource.data.utilityDeposit >= 0
        && request.resource.data.monthlyRent is number
        && request.resource.data.monthlyRent >= 0
        && paymentHistoryMatchesRentalRequest();
    }

    function ownerCanRejectRentalRequest() {
      return signedIn()
        && resource.data.ownerId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.tenantId == resource.data.tenantId
        && request.resource.data.status == 'rejected'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
    }

    function ownerCanApproveRentalRequest() {
      return signedIn()
        && resource.data.ownerId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.tenantId == resource.data.tenantId
        && request.resource.data.status == 'approved'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'payment', 'updatedAt'])
        && request.resource.data.payment.status == 'unpaid'
        && request.resource.data.payment.rentDeposit is number
        && request.resource.data.payment.rentDeposit >= 0
        && request.resource.data.payment.utilityDeposit is number
        && request.resource.data.payment.utilityDeposit >= 0
        && request.resource.data.payment.monthlyRent is number
        && request.resource.data.payment.monthlyRent >= 0
        && request.resource.data.payment.totalDue is number
        && request.resource.data.payment.totalDue >= 0;
    }

    function ownerCanUpdateMonthlyUtilities() {
      return signedIn()
        && resource.data.ownerId == request.auth.uid
        && resource.data.status == 'approved'
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.tenantId == resource.data.tenantId
        && request.resource.data.status == resource.data.status
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['payment', 'updatedAt'])
        && request.resource.data.payment.diff(resource.data.payment).affectedKeys().hasOnly(['monthlyUtilities']);
    }

    function tenantCanMarkRentalRequestPaid() {
      return signedIn()
        && resource.data.tenantId == request.auth.uid
        && request.resource.data.tenantId == resource.data.tenantId
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.status == resource.data.status
        && resource.data.status == 'approved'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['payment', 'updatedAt'])
        && resource.data.payment.status == 'unpaid'
        && request.resource.data.payment.status == 'paid'
        && request.resource.data.payment.rentDeposit == resource.data.payment.rentDeposit
        && request.resource.data.payment.utilityDeposit == resource.data.payment.utilityDeposit
        && request.resource.data.payment.monthlyRent == resource.data.payment.monthlyRent
        && request.resource.data.payment.totalDue == resource.data.payment.totalDue
        && request.resource.data.payment.diff(resource.data.payment).affectedKeys().hasOnly(['status', 'paidAt']);
    }

    match /users/{uid} {
      allow create: if (
          isSelf(uid)
          && request.resource.data.uid == uid
          && request.resource.data.role in ['tenant', 'owner']
          && hasValidCustomerRoles(request.resource.data.role)
          && request.resource.data.email is string
          && request.resource.data.name is string
        )
        || isInvitedAdminCreate(uid);

      allow get: if isSelf(uid) || isAdmin();
      allow list: if isAdmin();

      allow update: if isAdmin()
        || (
          isSelf(uid)
          && request.resource.data.uid == uid
          && request.resource.data.role in ['tenant', 'owner']
          && hasValidCustomerRoles(request.resource.data.role)
          && request.resource.data.email is string
          && request.resource.data.name is string
        );

      allow delete: if isAdmin();
    }

    match /adminInvites/{email} {
      allow get: if isBossAdmin()
        || (signedIn() && request.auth.token.email == email);
      allow list: if isBossAdmin();
      allow create, update: if isBossAdmin()
        && request.resource.data.email == email
        && request.resource.data.employeeRole in ['manager', 'property-staff', 'finance-staff']
        && request.resource.data.status in ['invited', 'accepted'];
      allow delete: if isBossAdmin();
    }

    match /properties/{propertyId} {
      allow read: if resource.data.status == 'available'
        || isAdmin()
        || (signedIn() && resource.data.ownerId == request.auth.uid);

      allow create: if isOwnerRole()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status in ['available', 'pending', 'rented']
        && request.resource.data.type in ['Room', 'Apartment', 'House', 'Condo'];

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.status in ['available', 'pending', 'rented']
          && request.resource.data.type in ['Room', 'Apartment', 'House', 'Condo']
        );

      allow delete: if isAdmin()
        || (signedIn() && resource.data.ownerId == request.auth.uid);
    }

    match /rentalRequests/{requestId} {
      allow create: if isTenant()
        && request.resource.data.tenantId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.contractYears is number
        && request.resource.data.contractYears >= 1
        && request.resource.data.contractYears <= 5;

      allow get, list: if isAdmin()
        || (
          signedIn()
          && (
            resource.data.tenantId == request.auth.uid
            || resource.data.ownerId == request.auth.uid
          )
        );

      allow update: if isAdmin()
        || ownerCanRejectRentalRequest()
        || ownerCanApproveRentalRequest()
        || ownerCanUpdateMonthlyUtilities()
        || tenantCanMarkRentalRequestPaid();

      allow delete: if isAdmin();
    }

    match /paymentMethods/{paymentMethodId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type in ['card', 'google-pay', 'fpx'];

      allow get, list: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.type in ['card', 'google-pay', 'fpx']
        );

      allow delete: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /paymentHistory/{paymentHistoryId} {
      allow create: if isValidPaymentHistoryCreate();

      allow get, list: if isAdmin()
        || (
          signedIn()
          && (
            resource.data.tenantId == request.auth.uid
            || resource.data.ownerId == request.auth.uid
          )
        );

      allow update, delete: if isAdmin();
    }

    match /conversations/{conversationId} {
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2;

      allow get, list: if isAdmin()
        || (signedIn() && request.auth.uid in resource.data.participantIds);

      allow update: if isAdmin()
        || (
          signedIn()
          && request.auth.uid in resource.data.participantIds
          && request.resource.data.participantIds == resource.data.participantIds
        );

      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow create: if signedIn()
          && exists(/databases/$(database)/documents/conversations/$(conversationId))
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          && request.resource.data.senderId == request.auth.uid;

        allow get, list: if isAdmin()
          || (
            signedIn()
            && exists(/databases/$(database)/documents/conversations/$(conversationId))
            && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          );

        allow update, delete: if isAdmin();
      }
    }

    match /enquiries/{enquiryId} {
      allow create: if isValidPublicEnquiryCreate();
      allow read, update, delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow create: if isValidPublicAppointmentCreate();
      allow read, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if signedIn()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow get, list: if isAdmin()
        || (signedIn() && resource.data.customerId == request.auth.uid);

      allow update: if isAdmin()
        && request.resource.data.status in ['pending', 'approved', 'rejected'];

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
